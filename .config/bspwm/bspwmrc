#!/usr/bin/env bash

#     __
#    / /_  _________ _      ______ ___
#   / __ \/ ___/ __ \ | /| / / __ `__ \
#  / /_/ (__  ) /_/ / |/ |/ / / / / / /
# /_.___/____/ .___/|__/|__/_/ /_/ /_/
#           /_/
#

_config="${XDG_CONFIG_HOME:-$HOME/.config}/bspwm"

# Restore wallpaper
nitrogen --restore &

# Fix the pointer for BSPWM
xsetroot -cursor_name left_ptr &

# Set configurations
for i in "$_config"/configs/*.sh; do
	{
		bash "$i" &
	}
done

# Set rules
for i in "$_config"/rules/*.sh; do
	{
		bash "$i" &
	}
done

# Enable Super Keys For Menu (skip if ksuperkey not installed)
if command -v ksuperkey >/dev/null 2>&1; then
	killall -9 ksuperkey 2>/dev/null || true
	ksuperkey -e 'Super_L=Alt_L|F1' &
	ksuperkey -e 'Super_R=Alt_L|F1' &
fi

# Polkit agent (skip if not installed)
_polkit=$(command -v xfce-polkit || command -v lxpolkit || command -v /usr/lib/xfce-polkit/xfce-polkit 2>/dev/null || true)
if [ -n "$_polkit" ] && ! pgrep -x "$(basename "$_polkit")" >/dev/null 2>&1; then
	"$_polkit" &
fi

# Delete existing hooks and restart them
for i in "$_config"/hooks/*; do
	{
		pkill -9 -f "$i"
		eval "$i" &
	}
done

# Autostart apps
eval "$_config/autostart.sh" &
